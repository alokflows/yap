{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ripple",
  "version": "0.1.0",
  "identifier": "com.alokflows.ripple",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ripple",
        "width": 440,
        "height": 680,
        "minWidth": 360,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
